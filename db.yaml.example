# ── PyKYCH 数据库配置模板 ──────────────────────────────────
# 复制此文件为 settings/db.yaml 并填入实际值。
# settings/db.yaml 已在 .gitignore 中，不会被提交到版本控制。

mysql:
  # 服务器地址
  host: kych.net

  # 端口 (MySQL 默认 3306)
  port: 3306

  # 数据库用户
  user: pykych

  # 数据库密码
  password: CHANGEME

  # 统一数据库名（所有表存放在同一数据库中）
  database: pykych

  # 字符集
  charset: utf8mb4

  # 连接池配置
  pool:
    minsize: 2
    maxsize: 10
    pool_recycle: 3600
